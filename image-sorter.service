[Unit]
Description=Sky Image Sorter Web Application
After=network.target

[Service]
Type=simple
User=user
WorkingDirectory=/home/user/image-sorter
ExecStart=/home/user/image-sorter/target/release/image-sorter
Restart=on-failure
RestartSec=5
Environment=RUST_LOG=info

[Install]
WantedBy=multi-user.target
