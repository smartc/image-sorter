# Rust build artifacts
/target/
**/*.rs.bk
*.pdb

# Debug/Release builds
debug/
target/

# Note: Cargo.lock is committed for executables/binaries but should be in .gitignore for libraries
# This is an executable, so Cargo.lock will be tracked
# More information: https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html

